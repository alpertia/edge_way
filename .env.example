# EdgeWay cihaz config sablonu — /etc/edgeway/edgeway.env olarak kopyala, chmod 600
EDGEWAY_SITE_ID=site-001
EDGEWAY_DEVICE_ID=edgeway-001
EDGEWAY_DATA_DIR=/var/lib/edgeway
EDGEWAY_SEGMENT_SECONDS=60
EDGEWAY_RETENTION_DAYS=90
EDGEWAY_DISK_MAX_PERCENT=85
# kameralar: ad=rtsp_url virgülle; sifreyi MASKED birakma, gercek degeri SADECE bu dosyaya yaz
EDGEWAY_CAMERAS=cam1=rtsp://admin:MASKED@192.168.0.4:554/h264/ch1/main/av_stream
EDGEWAY_MEDIAMTX_HLS=http://127.0.0.1:8888
EDGEWAY_API_PORT=8080
EDGEWAY_API_TOKEN=MASKED_UZUN_RASTGELE
EDGEWAY_S3_BUCKET=
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCESS_KEY_ID=MASKED
AWS_SECRET_ACCESS_KEY=MASKED
EDGEWAY_CLOUD_URL=
EDGEWAY_CLOUD_TOKEN=MASKED
EDGEWAY_HEARTBEAT_SECONDS=15
EDGEWAY_TEMP_WARN=70
EDGEWAY_TEMP_CRIT=78
EDGEWAY_TEMP_SHUTDOWN=82
