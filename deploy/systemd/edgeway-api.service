[Unit]
Description=EdgeWay API + web portal
After=network-online.target
[Service]
User=edgeway
EnvironmentFile=/etc/edgeway/edgeway.env
WorkingDirectory=/opt/edgeway
ExecStart=/opt/edgeway/.venv/bin/uvicorn edgeway.api.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
